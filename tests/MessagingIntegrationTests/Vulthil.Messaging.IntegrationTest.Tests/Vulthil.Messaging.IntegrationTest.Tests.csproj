<Project Sdk="Microsoft.NET.Sdk">

	<Import Project="$([MSBuild]::GetPathOfFileAbove('Vulthil.TestRunner.props', '$(MSBuildThisFileDirectory)'))" />

	<ItemGroup>
		<PackageReference Include="Aspire.Hosting.Testing" />
		<PackageReference Include="Aspire.RabbitMQ.Client" />
		<PackageReference Include="Microsoft.Extensions.Http.Resilience" />
		<!-- This project alone is run through the Aspire DCP host, which intermittently
		     times out starting in CI; eng/coverage.ps1 runs it as a separate, retried dotnet
		     test invocation so the retry extension never reaches other suites. -->
		<PackageReference Include="Microsoft.Testing.Extensions.Retry" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Vulthil.Messaging.IntegrationTest.AppHost\Vulthil.Messaging.IntegrationTest.AppHost.csproj" />
		<ProjectReference Include="..\Vulthil.Messaging.IntegrationTest.Contracts\Vulthil.Messaging.IntegrationTest.Contracts.csproj" />
		<ProjectReference Include="..\..\..\src\Vulthil.Extensions.Testing\Vulthil.Extensions.Testing.csproj" />
		<ProjectReference Include="..\..\..\src\Vulthil.Messaging.Abstractions\Vulthil.Messaging.Abstractions.csproj" />
	</ItemGroup>

</Project>
